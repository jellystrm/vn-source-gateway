# Copy this file to .env and fill in your values
# cp .env.example .env

# User/group ID — match your OMV user (run: id $USER)
PUID=1000
PGID=1000
TZ=Asia/Ho_Chi_Minh

# URL that Radarr/Sonarr use to reach this container
PUBLIC_BASE_URL=http://192.168.1.100:8765

# Torznab API key — set the same in Radarr/Sonarr indexer config
TORZNAB_API_KEY=vn-source

# TMDB API key — required for season expansion and title resolution
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Server labels shown in Radarr/Sonarr interactive search (comma-separated)
SERVER_LABELS=ViệtSub,Lồng Tiếng

# qBittorrent credentials (for download mode)
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# Output mode: strm (default) or download
DEFAULT_OUTPUT_MODE=strm
EXPOSE_BOTH_MODES=false

# Container paths (do not change unless you remap volumes)
DOWNLOAD_ROOT=/downloads/vn
MOVIE_STRM_ROOT=/movies
SERIES_STRM_ROOT=/shows
DOWNLOAD_CONTAINER=mkv

POLL_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
UI_PORT=8765

# Host paths — adjust to your OMV shared folder locations
APPDATA_PATH=/srv/dev-disk-by-uuid-XXXX/appdata
DOWNLOADS_PATH=/srv/dev-disk-by-uuid-XXXX/downloads
MOVIES_PATH=/srv/dev-disk-by-uuid-XXXX/media/movies
SHOWS_PATH=/srv/dev-disk-by-uuid-XXXX/media/shows
