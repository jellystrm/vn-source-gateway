# Copy file này thành .env rồi điền thông tin thực
# cp .env.example .env

# User/group ID — chạy lệnh: id $USER
PUID=1000
PGID=1000
TZ=Asia/Ho_Chi_Minh

# IP máy OMV mà Radarr/Sonarr dùng để gọi vào container này
PUBLIC_BASE_URL=http://192.168.1.100:8765

# API key cho Torznab — điền y hệt vào Radarr/Sonarr khi thêm indexer
TORZNAB_API_KEY=vn-source

# TMDB API key — cần thiết để expand season và resolve tên phim
# Lấy miễn phí tại: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Nhãn server hiện trong Radarr/Sonarr khi tìm kiếm (cách nhau bởi dấu phẩy)
SERVER_LABELS=ViệtSub,Lồng Tiếng

# Tài khoản qBittorrent (chỉ cần nếu dùng chế độ download)
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# Chế độ xuất: strm (mặc định) hoặc download
DEFAULT_OUTPUT_MODE=strm
EXPOSE_BOTH_MODES=false

# Đường dẫn bên trong container — không cần đổi
DOWNLOAD_ROOT=/downloads/vn
MOVIE_STRM_ROOT=/movies
SERIES_STRM_ROOT=/shows
DOWNLOAD_CONTAINER=mkv

POLL_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
UI_PORT=8765
