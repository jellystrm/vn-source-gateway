# Sao chép file này thành .env rồi điền thông tin thực
# cp .env.example .env

# ── TMDB (bắt buộc để resolve tên phim/series) ───────────────────────────────
# Lấy free key tại: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Download client (Radarr/Sonarr kết nối với credentials này) ──────────────
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# ── Torznab indexer ───────────────────────────────────────────────────────────
# Tự sinh khi lần đầu khởi động; copy giá trị sinh ra vào đây để giữ ổn định
# qua các lần restart container.
TORZNAB_API_KEY=

# URL deceptarr quảng bá cho Radarr/Sonarr dùng để grab link.
# Mặc định tự detect theo host của Radarr/Sonarr.
PUBLIC_BASE_URL=http://deceptarr:8765

# Label thêm vào tên release trong Torznab (phân cách bằng dấu phẩy).
SERVER_LABELS=ViệtSub,Lồng Tiếng

# Nhóm kết quả Torznab theo nguồn (true/false).
TORZNAB_GROUP_SOURCES=false

# ── Output ────────────────────────────────────────────────────────────────────
# strm   → ghi file .strm trỏ HLS URL (khuyến nghị, không tốn disk)
# hls-dl → tải stream HLS về file local qua ffmpeg
DEFAULT_OUTPUT_MODE=strm

# Hiển thị cả strm lẫn hls-dl trong kết quả Torznab.
EXPOSE_BOTH_MODES=false

# Container cho hls-dl (mkv / mp4 / ts).
DOWNLOAD_CONTAINER=mkv

# Cách Radarr/Sonarr import file (Move / Copy / Hardlink).
IMPORT_MODE=Move

# ── Đường dẫn ─────────────────────────────────────────────────────────────────
DOWNLOAD_ROOT=/downloads
MOVIE_STRM_ROOT=/movies
SERIES_STRM_ROOT=/shows

# ── Worker ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
MAX_ITEMS_PER_POLL=20

# ── UI / server ───────────────────────────────────────────────────────────────
UI_PORT=8765
LOG_LEVEL=INFO

# ── Custom HLS sources (nâng cao) ────────────────────────────────────────────
# Mảng JSON các nguồn HLS tự định nghĩa. Để trống để dùng nguồn built-in.
# HLS_TEMPLATE_SOURCES_JSON=[{"name":"my-src","movie_url_template":"https://.../{tmdb_id}.m3u8","series_url_template":"https://.../{tvdb_id}/s{season:02d}e{episode:02d}.m3u8"}]

# Thứ tự ưu tiên nguồn (phân cách bằng dấu phẩy).
# SOURCE_ORDER=kkphim,ophim,nguonc
