#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_DIR="${ROOT_DIR}/.local"

mkdir -p \
  "${LOCAL_DIR}/config" \
  "${LOCAL_DIR}/state" \
  "${LOCAL_DIR}/downloads" \
  "${LOCAL_DIR}/movies" \
  "${LOCAL_DIR}/shows"

export CONFIG_PATH="${CONFIG_PATH:-${LOCAL_DIR}/config/config.json}"
export STATE_PATH="${STATE_PATH:-${LOCAL_DIR}/state/state.json}"
export DOWNLOAD_ROOT="${DOWNLOAD_ROOT:-${LOCAL_DIR}/downloads}"
export MOVIE_STRM_ROOT="${MOVIE_STRM_ROOT:-${LOCAL_DIR}/movies}"
export SERIES_STRM_ROOT="${SERIES_STRM_ROOT:-${LOCAL_DIR}/shows}"
export PUBLIC_BASE_URL="${PUBLIC_BASE_URL:-http://127.0.0.1:${UI_PORT:-8765}}"
export UI_HOST="${UI_HOST:-127.0.0.1}"
export UI_PORT="${UI_PORT:-8765}"

cd "${ROOT_DIR}"
echo "vn-source-worker UI: http://127.0.0.1:${UI_PORT}"
echo "config: ${CONFIG_PATH}"
python3 -m vn_source_worker "$@"
